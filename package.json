{
  "name": "zotero-pageindex-gpt",
  "version": "0.2.8",
  "description": "Zotero GPT with PageIndex retrieval",
  "config": {
    "addonName": "Zotero PageIndex GPT",
    "addonID": "zotero-pageindex-gpt@huangfu170.github.io",
    "addonRef": "zoteropageindexgpt",
    "addonInstance": "ZoteroPageIndexGPT",
    "releasepage": "",
    "updaterdf": ""
  },
  "main": "src/index.ts",
  "scripts": {
    "build-dev": "cross-env NODE_ENV=development node scripts/build.js",
    "build-prod": "cross-env NODE_ENV=production node scripts/build.js",
    "build": "concurrently -c auto npm:build-prod npm:tsc",
    "tsc": "tsc --noEmit",
    "start-z6": "node scripts/start.js --z 6",
    "start-z7": "node scripts/start.js --z 7",
    "start": "node scripts/start.js",
    "stop": "node scripts/stop.js",
    "restart-dev": "npm run build-dev && npm run stop && npm run start",
    "restart-prod": "npm run build-prod && npm run stop && npm run start",
    "restart": "npm run restart-dev",
    "pageindex": "python pageindex_service/server.py",
    "release": "release-it",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huangfu170/zotero-pageindex-gpt.git"
  },
  "author": "huangfu170",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/huangfu170/zotero-pageindex-gpt/issues"
  },
  "homepage": "https://github.com/huangfu170/zotero-pageindex-gpt",
  "dependencies": {
    "compute-cosine-similarity": "^1.0.0",
    "crypto-js": "^4.1.1",
    "langchain": "^0.0.66",
    "lighten-darken-color": "^1.0.0",
    "markdown-it": "^13.0.1",
    "markdown-it-mathjax3": "^4.3.2",
    "terser": "^5.17.1",
    "zotero-plugin-toolkit": "^2.0.1"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.1.1",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^18.11.17",
    "compressing": "^1.6.3",
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.17.4",
    "esbuild-plugin-wasm": "^1.0.0",
    "minimist": "^1.2.7",
    "punycode": "^2.3.0",
    "release-it": "^15.6.0",
    "replace-in-file": "^6.3.5",
    "typescript": "^5.0.4",
    "uglify-js": "^3.17.4",
    "zotero-types": "^1.0.12"
  }
}
